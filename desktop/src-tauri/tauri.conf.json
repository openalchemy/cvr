{
  "$schema": "https://raw.githubusercontent.com/nicedoc/json-schemas/main/tauri-v2/tauri.conf.json",
  "productName": "CVR",
  "version": "0.1.0",
  "identifier": "io.openalchemy.cvr",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CVR",
        "width": 1100,
        "height": 750,
        "minWidth": 700,
        "minHeight": 500,
        "decorations": false,
        "resizable": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
